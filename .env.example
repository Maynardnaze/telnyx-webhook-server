TZ=America/Detroit
DOMAINNAME_1=miswitch.cloud
TELNYX_DIRECTORY_GUEST_SERVICES_PHONE=+124****0000

# SQLite database for async jobs and Telnyx insight payloads.
# In Docker Compose this is set to /data/webhook.db and persisted in ./data/.
# WEBHOOK_DB_PATH=/data/webhook.db

# Telnyx public key from Mission Control Portal webhook/signing settings.
# This is a public verification key, so it can live in .env.
# When set, Insight Groups can POST to /telnyx/insights without ?secret=.
TELNYX_PUBLIC_KEY=

# Local development only — disables shared-secret checks on protected endpoints.
# WEBHOOK_ALLOW_NO_SECRET=1

# Optional overrides (defaults are usually fine):
# DIRECTORY_DATA=tenants.json
# WEBHOOK_SECRET=change-me-local-test
# ASYNC_MOCK_DELAY_SECONDS=0.25

# Legacy JSON paths — used only for one-time import into SQLite on first startup:
# WEBHOOK_JOBS_PATH=/data/jobs.json
# WEBHOOK_INSIGHTS_PATH=/data/insights.json
